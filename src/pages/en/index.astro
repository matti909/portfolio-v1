---
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/ui/Container.astro'
import { getCollection, getEntry } from "astro:content"
import { getLangFromUrl, useTranslations } from '../../i18n/utils'

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const experiences = await getCollection("experience", ({ data }) => data.lang === lang);
const projects = await getCollection("projects", ({ data }) => data.lang === lang);

const siteConfig = await getEntry("site", lang);
if (!siteConfig) {
  throw new Error("Site configuration not found");
}

const site = siteConfig.data;
const [featuredProject, ...otherProjects] = projects;

const STACK = ["Astro","React","Node.js","TypeScript","PostgreSQL","Docker","GraphQL","REST","Next.js","Tailwind"];
---

<Layout title={`${site.name} - ${site.title}`}>
  <Container>

    <!-- ─── HERO ───────────────────────────────────── -->
    <section class="hero">
      <div class="hero-eyebrow">
        <span class="eyebrow-label">Portfolio · 2025</span>
        <span class="availability">
          <span class="avail-dot" aria-hidden="true"></span>
          <span>Available</span>
        </span>
      </div>

      <h1 class="hero-name" data-scramble>{site.name}</h1>

      <div class="hero-role-strip">
        <p class="hero-role">{site.title}</p>
      </div>

      <p class="introduction">{site.introduction}</p>

      {site.socialLinks && (
        <div class="social-links">
          {site.socialLinks.map(({ platform, url }) => (
            <a href={url} target="_blank" rel="noopener noreferrer" class="btn-brutal">
              {platform} ↗
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- ─── TICKER ──────────────────────────────────── -->
    <div class="ticker-wrapper" aria-hidden="true">
      <div class="ticker-track">
        {[...STACK, ...STACK].map(item => (
          <span class="ticker-item">{item}</span>
        ))}
      </div>
    </div>

    <!-- ─── PROJECTS ────────────────────────────────── -->
    <section class="section">
      <div class="section-divider">
        <span class="section-idx" aria-hidden="true">01</span>
        <div class="section-line" aria-hidden="true"></div>
        <h2>{site.sections.projects.title}</h2>
      </div>

      {featuredProject && (
        <article class="card-featured">
          <div class="featured-meta">
            <span class="featured-badge">★ Featured</span>
            <div class="project-links">
              {featuredProject.data.production && (
                <a href={featuredProject.data.production} target="_blank" rel="noopener noreferrer" class="featured-cta">
                  Visit ↗
                </a>
              )}
              {featuredProject.data.github && (
                <a href={featuredProject.data.github} target="_blank" rel="noopener noreferrer" class="featured-cta featured-cta--ghost">
                  GitHub
                </a>
              )}
            </div>
          </div>
          <h3 class="featured-title">{featuredProject.data.title}</h3>
          <p class="featured-desc">{featuredProject.data.description}</p>
          {featuredProject.data.techs && (
            <div class="tags">
              {featuredProject.data.techs.map((tech) => (
                <span class="tag-dark">{tech}</span>
              ))}
            </div>
          )}
        </article>
      )}

      {otherProjects.length > 0 && (
        <div class="projects-grid">
          {otherProjects.map((project) => (
            <article class="card-brutal">
              <div class="title-row">
                <span class="project-title">{project.data.title}</span>
                <div class="project-links">
                  {project.data.production && (
                    <a href={project.data.production} target="_blank" rel="noopener noreferrer" class="visit-link">
                      Visit
                    </a>
                  )}
                  {project.data.github && (
                    <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="github-link">
                      GitHub
                    </a>
                  )}
                </div>
              </div>
              <p class="text-muted">{project.data.description}</p>
              {project.data.techs && (
                <div class="tags">
                  {project.data.techs.map((tech) => (
                    <span>{tech}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      )}
    </section>

    <!-- ─── EXPERIENCE ──────────────────────────────── -->
    <section class="section">
      <div class="section-divider">
        <span class="section-idx" aria-hidden="true">02</span>
        <div class="section-line" aria-hidden="true"></div>
        <h2>{site.sections.experience.title}</h2>
      </div>

      <div class="timeline">
        {experiences.map((exp) => (
          <article class="timeline-item">
            <div class="timeline-dot" aria-hidden="true"></div>
            <div class="timeline-content">
              <div class="exp-header">
                <div class="company-info">
                  {exp.data.logo && (
                    <img src={exp.data.logo} alt={exp.data.company} class="company-logo"
                      width="40" height="40" loading="lazy" />
                  )}
                  <div class="company-details">
                    {exp.data.url ? (
                      <a href={exp.data.url} target="_blank" rel="noopener noreferrer" class="company-name">
                        {exp.data.company}
                      </a>
                    ) : (
                      <span class="company-name">{exp.data.company}</span>
                    )}
                    <span class="job-title">{exp.data.title}</span>
                  </div>
                </div>
                <time>
                  {exp.data.startDate.toLocaleDateString("en-US", { year: "numeric", month: "short" })} —
                  {exp.data.current
                    ? "Present"
                    : exp.data.endDate?.toLocaleDateString("en-US", { year: "numeric", month: "short" })}
                </time>
              </div>
              <p class="text-muted">{exp.data.description}</p>
              {exp.data.techs && (
                <div class="tags">
                  {exp.data.techs.map((tech) => (
                    <span>{tech}</span>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

  </Container>
</Layout>

<style>
  /* ── HERO ─────────────────────────────────────────── */
  .hero {
    padding: var(--space-3xl) 0 var(--space-xl);
  }

  .hero-eyebrow {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: var(--border-width) solid var(--border-color);
  }

  .eyebrow-label {
    font-size: var(--text-xs);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .availability {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 900;
    text-transform: uppercase;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    color: var(--text-color);
  }

  .avail-dot {
    width: 8px;
    height: 8px;
    background: #00C853;
    border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-dot 2.4s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.75); }
  }

  @media (prefers-reduced-motion: reduce) {
    .avail-dot { animation: none; }
  }

  .hero-name {
    margin-bottom: var(--space-lg);
    line-height: 0.95;
    cursor: default;
  }

  .hero-role-strip {
    display: inline-flex;
    align-items: center;
    background: var(--text-color);
    color: var(--bg-color);
    padding: var(--space-sm) var(--space-xl);
    margin-bottom: var(--space-xl);
    border: var(--border-width) solid var(--border-color);
  }

  .hero-role {
    font-size: var(--text-2xl);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0;
    color: inherit;
    font-family: var(--font-heading);
  }

  .introduction {
    font-size: var(--text-lg);
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  .social-links {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* ── SECTION DIVIDERS ─────────────────────────────── */
  .section {
    margin: var(--space-3xl) 0;
  }

  .section-divider {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: var(--border-width) solid var(--border-color);
  }

  .section-idx {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 900;
    color: var(--accent-primary);
    background: var(--bg-color-secondary);
    border: 2px solid var(--border-color);
    padding: 2px var(--space-sm);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .section-line {
    flex: 1;
    height: 2px;
    background: var(--border-color);
    opacity: 0.25;
  }

  .section-divider h2 {
    margin-bottom: 0;
    font-size: var(--text-2xl);
    white-space: nowrap;
  }

  /* ── FEATURED PROJECT ─────────────────────────────── */
  .card-featured {
    background: var(--accent-warning);
    border: var(--border-width) solid var(--border-color);
    padding: var(--space-2xl);
    box-shadow: var(--shadow-brutal);
    margin-bottom: var(--space-xl);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    color: #000;
  }

  [data-theme="dark"] .card-featured {
    background: var(--accent-primary);
    color: #000;
  }

  .card-featured:hover {
    transform: translate(-4px, -4px);
    box-shadow: var(--shadow-brutal-hover);
  }

  .featured-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-lg);
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .featured-badge {
    font-size: var(--text-xs);
    font-weight: 900;
    text-transform: uppercase;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    background: #000;
    color: var(--accent-warning);
    padding: 2px var(--space-sm);
  }

  [data-theme="dark"] .featured-badge {
    color: var(--accent-primary);
  }

  .featured-title {
    font-size: var(--text-3xl);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    color: #000;
  }

  .featured-desc {
    font-size: var(--text-lg);
    color: #000;
    opacity: 0.75;
    margin-bottom: var(--space-md);
  }

  .featured-cta {
    font-size: var(--text-sm);
    font-weight: 900;
    text-transform: uppercase;
    padding: var(--space-xs) var(--space-md);
    background: #000;
    color: var(--accent-warning);
    border: 2px solid #000;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    touch-action: manipulation;
  }

  [data-theme="dark"] .featured-cta {
    color: var(--accent-primary);
  }

  .featured-cta:hover {
    color: var(--accent-warning);
    transform: translate(-2px, -2px);
    box-shadow: 3px 3px 0 #000;
  }

  [data-theme="dark"] .featured-cta:hover {
    color: var(--accent-primary);
  }

  .featured-cta--ghost {
    background: transparent;
    color: #000;
  }

  .featured-cta--ghost:hover {
    background: #000;
    color: var(--accent-warning);
  }

  [data-theme="dark"] .featured-cta--ghost {
    color: #000;
  }

  .project-links {
    display: flex;
    gap: var(--space-sm);
  }

  /* ── PROJECTS GRID ────────────────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 580px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .project-title {
    font-weight: 700;
  }

  .visit-link {
    font-size: var(--text-sm);
    padding: var(--space-xs) var(--space-sm);
    background: var(--accent-primary);
    border: 2px solid var(--border-color);
    color: #000;
    font-weight: 700;
    white-space: nowrap;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    touch-action: manipulation;
  }

  .visit-link:hover {
    transform: translate(-2px, -2px);
    box-shadow: 3px 3px 0 var(--border-color);
  }

  .github-link {
    font-size: var(--text-sm);
    padding: var(--space-xs) var(--space-sm);
    background: var(--bg-color-secondary);
    border: 2px solid var(--border-color);
    white-space: nowrap;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    touch-action: manipulation;
  }

  .github-link:hover {
    transform: translate(-2px, -2px);
    box-shadow: 3px 3px 0 var(--border-color);
  }

  /* ── TAGS ─────────────────────────────────────────── */
  .tags {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    flex-wrap: wrap;
  }

  .tags span {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    padding: var(--space-xs) var(--space-sm);
    background: var(--accent-primary);
    border: 2px solid var(--border-color);
    color: #000;
  }

  .tag-dark {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    padding: var(--space-xs) var(--space-sm);
    background: #000;
    border: 2px solid #000;
    color: var(--accent-warning);
  }

  [data-theme="dark"] .tag-dark {
    background: rgba(0,0,0,0.6);
    border-color: #000;
    color: var(--accent-primary);
  }

  /* ── TIMELINE ─────────────────────────────────────── */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: var(--border-width) solid var(--border-color);
    padding-left: var(--space-2xl);
  }

  .timeline-item {
    position: relative;
    padding-bottom: var(--space-2xl);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: calc(-1 * var(--space-2xl) - 10px);
    top: 4px;
    width: 16px;
    height: 16px;
    background: var(--accent-primary);
    border: 3px solid var(--border-color);
  }

  [data-theme="dark"] .timeline-dot {
    box-shadow: 0 0 8px var(--accent-primary);
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .company-info {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .company-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .company-name {
    font-weight: 700;
  }

  .job-title {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .company-logo {
    width: 2.5rem;
    height: 2.5rem;
    object-fit: contain;
    border: 2px solid var(--border-color);
  }

  time {
    font-size: var(--text-sm);
    color: var(--text-muted);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    font-family: var(--font-mono);
    background: var(--bg-color-secondary);
    border: 2px solid var(--border-color);
    padding: 2px var(--space-sm);
    flex-shrink: 0;
  }

  /* ── RESPONSIVE ───────────────────────────────────── */
  @media (max-width: 640px) {
    .hero {
      padding: var(--space-2xl) 0 var(--space-xl);
    }

    .hero-role {
      font-size: var(--text-xl);
    }

    .section-divider h2 {
      font-size: var(--text-xl);
    }

    .featured-title {
      font-size: var(--text-2xl);
    }

    .exp-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .timeline {
      padding-left: var(--space-xl);
    }

    .timeline-dot {
      left: calc(-1 * var(--space-xl) - 10px);
    }
  }
</style>

<script>
  const scrambleEl = document.querySelector('[data-scramble]') as HTMLElement;
  if (scrambleEl && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const original = scrambleEl.textContent ?? '';
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';

    function scramble(el: HTMLElement, text: string) {
      let iterations = 0;
      const interval = setInterval(() => {
        el.textContent = text
          .split('')
          .map((char, i) => {
            if (char === ' ') return ' ';
            if (i < iterations) return text[i];
            return chars[Math.floor(Math.random() * chars.length)];
          })
          .join('');
        iterations += 0.4;
        if (iterations >= text.length) {
          el.textContent = text;
          clearInterval(interval);
        }
      }, 35);
    }

    scramble(scrambleEl, original);
    scrambleEl.addEventListener('mouseenter', () => scramble(scrambleEl, original));
  }
</script>
