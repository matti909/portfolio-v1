---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const year = new Date().getFullYear();

const copy = {
  es: { cta: "Hablemos", stack: "Construido con" },
  en: { cta: "Let's talk", stack: "Built with" },
};

const t = copy[lang as 'es' | 'en'];
---

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="brand-mark">&lt;matti /&gt;</span>
        <p class="brand-tagline">Matti Dev · FullStack</p>
      </div>
      <a
        href={lang === 'es' ? '/contact' : '/en/contact'}
        class="footer-cta"
        aria-label={t.cta}
      >
        {t.cta} ↗
      </a>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© {year} Matti Dev</p>
      <p class="footer-stack">
        {t.stack}
        <span class="stack-tag">Astro</span>
        <span class="stack-sep" aria-hidden="true">+</span>
        <span class="stack-tag">TypeScript</span>
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--text-color);
    color: var(--bg-color);
    border-top: var(--border-width-thick) solid var(--border-color);
    margin-top: var(--space-3xl);
  }

  [data-theme="dark"] footer {
    background: var(--bg-color-secondary);
    color: var(--text-color);
    border-top-color: var(--accent-primary);
  }

  .footer-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg);
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 2px solid rgba(255, 255, 255, 0.15);
    flex-wrap: wrap;
  }

  [data-theme="dark"] .footer-top {
    border-bottom-color: rgba(0, 255, 136, 0.2);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .brand-mark {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: 900;
    color: var(--accent-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .brand-tagline {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-family: var(--font-mono);
    opacity: 0.6;
    margin: 0;
    color: inherit;
  }

  .footer-cta {
    font-size: var(--text-lg);
    font-weight: 900;
    text-transform: uppercase;
    padding: var(--space-md) var(--space-xl);
    background: var(--accent-primary);
    color: #000;
    border: var(--border-width) solid var(--accent-primary);
    box-shadow: 4px 4px 0 var(--accent-primary);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    touch-action: manipulation;
  }

  [data-theme="dark"] .footer-cta {
    box-shadow: 4px 4px 0 rgba(0, 255, 136, 0.5);
  }

  .footer-cta:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 var(--accent-primary);
    color: #000;
  }

  [data-theme="dark"] .footer-cta:hover {
    box-shadow: 7px 7px 0 rgba(0, 255, 136, 0.6);
    color: #000;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-lg);
    padding-top: var(--space-xl);
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    opacity: 0.5;
    margin: 0;
    color: inherit;
  }

  .footer-stack {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    opacity: 0.6;
    margin: 0;
    color: inherit;
  }

  .stack-tag {
    color: var(--accent-primary);
    font-weight: 900;
  }

  .stack-sep {
    opacity: 0.4;
  }

  @media (max-width: 640px) {
    .footer-inner {
      padding: var(--space-xl) var(--space-md);
    }

    .footer-top {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-cta {
      width: 100%;
      text-align: center;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }
  }
</style>
